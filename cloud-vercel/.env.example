# NikkoMusicHub Vercel / Cloud environment variables
# Copy this file to .env.local (or use Vercel encrypted environment variables).
# Do NOT commit real secrets, tokens, or passwords to Git.
#
# === REQUIRED ===  Set these before deploying to production.
# === OPTIONAL ===  Leave blank or keep defaults if not needed.

NODE_ENV=production

# --- Cloud admin authentication (required in production) ---
# Required in production. Must be at least 32 characters.
NIKKO_CLOUD_SECRET=
NIKKO_ADMIN_USER=
# Plain text is accepted for initial setup; prefer bcrypt hash in the future.
NIKKO_ADMIN_PASS=

# --- Supabase (required for multi-device persistence) ---
SUPABASE_URL=
# This proxy secret is shared with the Supabase Edge Function only.
NIKKO_SUPABASE_PROXY_SECRET=

# --- MQTT connection (defaults match a fresh Pi install) ---
NIKKO_MQTT_BROKER=114.55.1.51
NIKKO_MQTT_PORT=1883
NIKKO_MQTT_USERNAME=admin
# Default placeholder password. Change in production.
NIKKO_MQTT_PASSWORD=topup30%off
# Must match the Pi's NIKKO_MQTT_COMMAND_SECRET.
NIKKO_MQTT_COMMAND_SECRET=topup30%off
# Must match the Pi's NIKKO_MQTT_TOPIC_PREFIX (default on Pi is `nikko`).
NIKKO_MQTT_TOPIC_PREFIX=nikko
# Set to 0 to skip certificate verification when using a self-signed broker cert.
NIKKO_MQTT_TLS_VERIFY=0
# PEM-encoded private broker Root CA and certificate CN/SNI name.
NIKKO_MQTT_CA=
NIKKO_MQTT_TLS_SERVERNAME=

# --- Notifications (optional) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
NIKKO_WEBHOOK_URL=
