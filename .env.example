# NikkoMusicHub Pi environment variables
# Copy this file to /srv/nikko-music/data/nikko.env and fill in real values.
# Do NOT commit real secrets or passwords to Git.

# --- Web / JWT ---
NODE_ENV=production
NIKKO_PORT=8080
# Required in production. Must be at least 32 characters.
NIKKO_SECRET_KEY=
# Set to 1/true in production to mark cookies as secure (requires HTTPS).
NIKKO_COOKIE_SECURE=0

# --- Initial admin credentials (only used on first install) ---
# If not set, a random password is generated in data/initial-admin-password.
# NIKKO_DEFAULT_PASSWORD=
NIKKO_USER=pi
NIKKO_GROUP=pi

# --- MQTT (central cloud management) ---
# Default broker used by install.sh. Use a private broker in production.
NIKKO_MQTT_BROKER=114.55.1.51
NIKKO_MQTT_PORT=1883
NIKKO_MQTT_USERNAME=admin
# Default placeholder password. Change in production.
NIKKO_MQTT_PASSWORD=topup30%off
# Shared secret between Cloud and Pi for signed commands.
NIKKO_MQTT_COMMAND_SECRET=topup30%off
# Private topic prefix.
NIKKO_MQTT_TOPIC_PREFIX=nikko
NIKKO_MQTT_STORE_ID=
# TLS is disabled by default; set to 1 in production with a trusted broker.
NIKKO_MQTT_TLS=0
# Set to 0 to skip certificate verification when using a self-signed broker cert.
NIKKO_MQTT_TLS_VERIFY=0
# Required for a private broker that uses its own CA.
NIKKO_MQTT_CA_PATH=/srv/nikko-music/data/mqtt-ca.pem
NIKKO_MQTT_COMMAND_MAX_AGE_SECONDS=60

# --- Sync ---
NIKKO_AUTO_RESTART_PLAYER=1
