[Unit]
Description=NikkoMusicHub Web Management Interface
After=network.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/srv/nikko-music/app
Environment=PYTHONUNBUFFERED=1
Environment=NIKKO_PORT=8080
Environment=NIKKO_SECRET_KEY=%H-%M-%S-nikko-music-hub
ExecStart=/srv/nikko-music/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
